# computile-backup-agent — Exclusion patterns
# Copy to /etc/computile-backup/excludes.txt and edit.
# One pattern per line. See: https://restic.readthedocs.io/en/latest/040_backup.html#excluding-files

# Docker internal data (DB files are backed up via dumps)
/var/lib/docker/overlay2
/var/lib/docker/image
/var/lib/docker/containers/*/log-*
/var/lib/docker/buildkit
/var/lib/docker/tmp
/var/lib/docker/volumes

# Database raw data files (backed up via logical dumps instead)
# Note: bind-mounted DB directories are auto-excluded at runtime.
# These patterns catch any that slip through (named volumes mounted
# to host paths, non-standard locations, etc.)
# Uncomment or adapt as needed for your setup:
# /data/coolify/databases
# /data/coolify/services/*/mysql*
# /data/coolify/services/*/mariadb*
# /data/coolify/services/*/postgres*

# System temp / cache
/tmp
/var/tmp
/var/cache
/var/lib/apt
/var/lib/dpkg

# Swap & memory
*.swp
*.swap
/swapfile

# Logs (optional — uncomment to exclude)
# /var/log

# Node modules / vendor (usually reproducible)
**/node_modules
**/vendor
**/.venv
**/__pycache__

# Build artifacts (scoped to common app directories to avoid excluding
# Coolify internal data under /data/coolify)
/var/www/**/.next
/var/www/**/dist
/var/www/**/build
/home/**/.cache
/var/www/**/.cache

# OS files
.Trash*
*.DS_Store
Thumbs.db

# Restic cache
/var/cache/restic

# Backup temp files (our own dumps are included separately)
/var/backups/computile/tmp
