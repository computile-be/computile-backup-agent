# ================================================================
# computile-backup-agent — Configuration file
#
# Copy to /etc/computile-backup/backup-agent.conf and edit.
# ================================================================

# ----------------------------------------------
# Identity
# ----------------------------------------------
CLIENT_ID="client-name"
HOST_ID="vps-prod-01"
ENVIRONMENT="prod"          # prod, staging, dev
ROLE="coolify"              # coolify, forge, hybrid, docker, bare

# ----------------------------------------------
# Restic repository (via SFTP over Tailscale)
# ----------------------------------------------
RESTIC_REPOSITORY="sftp:backup-${CLIENT_ID}@backup-gateway:/srv/backups/backup-${CLIENT_ID}/data/${HOST_ID}"
RESTIC_PASSWORD_FILE="/etc/computile-backup/restic-password"
# RESTIC_CACHE_DIR="/var/cache/restic"

# ----------------------------------------------
# Paths
# ----------------------------------------------
BACKUP_ROOT="/var/backups/computile"
LOG_FILE="/var/log/computile-backup.log"

# Paths to include in backup
INCLUDE_PATHS=(
    /etc
    /home
    /root
    /var/www
    /opt
    /srv
    /data
    /data/coolify
)

# Exclusion file (one pattern per line)
EXCLUDE_FILE="/etc/computile-backup/excludes.txt"

# ----------------------------------------------
# Retention policy
# ----------------------------------------------
RETENTION_KEEP_DAILY=7
RETENTION_KEEP_WEEKLY=4
RETENTION_KEEP_MONTHLY=6
RETENTION_KEEP_YEARLY=2

# ----------------------------------------------
# Docker & database discovery
# ----------------------------------------------
DOCKER_ENABLED="yes"
DOCKER_DB_AUTO_DISCOVERY="yes"

# Per-database type toggle
MYSQL_DUMP_ENABLED="yes"
POSTGRES_DUMP_ENABLED="yes"
REDIS_SNAPSHOT_ENABLED="no"    # "yes" to enable Redis BGSAVE snapshots

# Days to keep local dump files before cleanup
DUMP_CLEANUP_DAYS=3

# ----------------------------------------------
# Host-level databases (Forge, bare metal, etc.)
# ----------------------------------------------
# Enable this for servers where MySQL/PostgreSQL runs directly on the host
# (not in Docker containers). Common with Laravel Forge, Ploi, etc.
HOST_DB_ENABLED="no"

# MySQL/MariaDB host credentials
# HOST_MYSQL_USER="root"
# HOST_MYSQL_PASS_FILE="/etc/computile-backup/mysql-password"
# HOST_MYSQL_DATABASES=""       # comma-separated, empty = all non-system DBs

# PostgreSQL host credentials (uses sudo -u for peer auth)
# HOST_POSTGRES_USER="postgres"
# HOST_POSTGRES_DATABASES=""    # comma-separated, empty = all non-template DBs

# ----------------------------------------------
# Manual database entries (optional, Docker only)
# ----------------------------------------------
# Format: "container_name|db_type|user|password|databases"
# - db_type: mysql, postgres, redis
# - databases: comma-separated list, or empty for all
# - password: leave empty to auto-detect from container env
#
# MANUAL_DBS=(
#     "my-mariadb|mysql|root||app_db,other_db"
#     "my-postgres|postgres|postgres||"
#     "custom-pg|postgres|myuser|mypassword|mydb"
# )

# ----------------------------------------------
# Email notifications (via msmtp)
# ----------------------------------------------
EMAIL_ENABLED="yes"
EMAIL_TO="alerts@computile.be"
EMAIL_FROM="backup@computile.email"
EMAIL_ON_SUCCESS="no"          # "yes" to also notify on success

# OVH SMTP settings
SMTP_HOST="ssl0.ovh.net"
SMTP_PORT="587"
SMTP_USER="backup@computile.email"
SMTP_PASS_FILE="/etc/computile-backup/smtp-password"

# ----------------------------------------------
# Healthcheck ping (healthchecks.io, Uptime Kuma, etc.)
# ----------------------------------------------
# Pings this URL on success, or URL/fail on failure.
# Leave empty to disable.
# HEALTHCHECK_URL="https://hc-ping.com/your-uuid-here"

# ----------------------------------------------
# Bandwidth & performance
# ----------------------------------------------
# Limit upload speed in KB/s (0 = unlimited)
# RESTIC_UPLOAD_LIMIT_KB=0

# Number of retries on transient SFTP failures (default: 2)
# RESTIC_RETRY_COUNT=2

# Minimum free disk space in MB before starting dumps (default: 500)
# DUMP_MIN_SPACE_MB=500

# ----------------------------------------------
# Verification
# ----------------------------------------------
VERIFY_AFTER_BACKUP="yes"
VERIFY_CHECK_DATA="no"        # "yes" to run restic check --read-data-subset

# ----------------------------------------------
# Misc
# ----------------------------------------------
VERBOSE="no"
DRY_RUN="no"
