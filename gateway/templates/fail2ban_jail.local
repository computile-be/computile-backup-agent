# computile-backup — fail2ban configuration for backup gateway
# Place in /etc/fail2ban/jail.local

[DEFAULT]
# Ban for 1 hour after 5 failures within 10 minutes
bantime  = 1h
findtime = 10m
maxretry = 5
# Use systemd journal for log reading
backend  = systemd

[sshd]
enabled  = true
port     = ssh
filter   = sshd
maxretry = 3
bantime  = 3600
